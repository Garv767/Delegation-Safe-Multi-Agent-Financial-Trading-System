{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile information stored in Firestore.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "The user's role in the system."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created."
        }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "User profile document indexed by UID."
    }
  }
}
